# Notificación por correo (opcional) — crea cuenta gratis en resend.com
# Sin esta variable el formulario funciona igual, solo no envía email
RESEND_API_KEY=
# Correo donde llegan los avisos (por defecto: ceronadrian770@gmail.com)
CONTACT_EMAIL=
